# ============================================================
# TradeNexus AI — Environment Configuration
# Copy this file to backend/.env and fill in the values.
# ============================================================

# ---- MongoDB ----
MONGO_URL=mongodb://localhost:27017
DB_NAME=tradenexus

# ---- Security ----
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production

# ---- CORS ----
# Comma-separated list of allowed frontend origins, or * for dev
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ---- AI / LLM ----
# Used for document intelligence parsing
EMERGENT_LLM_KEY=

# ---- Payments (Razorpay) ----
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ---- NBFC Partners ----
CREDLIX_API_URL=
CREDLIX_API_KEY=
DRIP_CAPITAL_API_URL=
DRIP_CAPITAL_API_KEY=
VAYANA_API_URL=
VAYANA_API_KEY=

# ---- WhatsApp Notifications (Twilio) ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ---- Frontend (React) ----
# Local dev: set in frontend/.env
# REACT_APP_BACKEND_URL=http://localhost:8001
# Railway: leave blank — React is served by the same FastAPI process

# ---- Railway ----
# PORT is injected automatically by Railway — do NOT set this manually
# FRONTEND_BUILD_DIR is optional — defaults to ../frontend/build relative to backend/
